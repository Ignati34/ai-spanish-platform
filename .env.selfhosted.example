# ============ General ============
APP_ENV=selfhosted
APP_NAME=AI Spanish Learning Platform
APP_URL=http://localhost:8080
API_URL=http://localhost:8000

# ============ Database / cache ============
DATABASE_URL=postgresql+psycopg://spanish_ai:spanish_ai_password@postgres:5432/spanish_ai
REDIS_URL=redis://redis:6379/0

# ============ Auth ============
JWT_SECRET=change_me_super_secret
JWT_ALGORITHM=HS256
JWT_EXPIRES_MINUTES=60
REFRESH_TOKEN_EXPIRES_DAYS=30

# ============ Object storage (MinIO / S3) ============
S3_ENDPOINT=http://minio:9000
S3_ACCESS_KEY=minio
S3_SECRET_KEY=minio_password
S3_BUCKET_UPLOADS=uploads
S3_BUCKET_GENERATED=generated
S3_REGION=us-east-1

# ============ AI gateway ============
# AI_PROVIDER=stub keeps everything working with no key (deterministic demo output).
# Set AI_PROVIDER=openai + AI_API_KEY to use a real OpenAI-compatible chat model.
AI_PROVIDER=stub
AI_API_KEY=change_me
AI_BASE_URL=https://api.openai.com/v1
AI_MODEL=gpt-4o-mini
AI_TEMPERATURE=0.2
AI_MAX_TOKENS=1400
AI_TIMEOUT_SECONDS=45
AI_CACHE_ENABLED=true
AI_CACHE_TTL_SECONDS=86400
STT_MODEL=gpt-4o-mini-transcribe
TTS_VOICE=alloy
TTS_FORMAT=mp3
TTS_MODEL=gpt-4o-mini-tts
IMAGE_MODEL=image_model_name
EMBEDDING_MODEL=embedding_model_name

# ============ Localization (native languages) ============
DEFAULT_INTERFACE_LANGUAGE=ru
SUPPORTED_LOCALES=ru,uk,ar,fr,es,en
RTL_LOCALES=ar
DEFAULT_CURRENCY=eur

# ============ Payments: choose enabled providers ============
# Any combination of: stripe, paypal, telegram
PAYMENT_PROVIDERS=stripe

# --- Stripe (cards + SEPA + Bizum for Spain, intl cards) ---
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_SUCCESS_URL=http://localhost:8080/app/billing?checkout=success
STRIPE_CANCEL_URL=http://localhost:8080/app/billing?checkout=cancelled
# Methods offered at Checkout. Spain-friendly defaults:
STRIPE_PAYMENT_METHOD_TYPES=card,sepa_debit,bizum,paypal
STRIPE_PRICE_BASIC_MONTHLY=
STRIPE_PRICE_PRO_MONTHLY=
STRIPE_PRICE_PREMIUM_MONTHLY=

# --- PayPal (international fallback) ---
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=
PAYPAL_WEBHOOK_ID=
PAYPAL_ENV=sandbox

# --- Telegram Payments (inside the Mini App) ---
# provider token from @BotFather (a PSP token: Stripe TEST, YooKassa, etc.)
TELEGRAM_PAYMENT_PROVIDER_TOKEN=
TELEGRAM_PAYMENT_CURRENCY=EUR

# --- Redsys / Bizum native (optional; Stripe already covers Bizum) ---
REDSYS_MERCHANT_CODE=
REDSYS_SECRET_KEY=
REDSYS_TERMINAL=1
REDSYS_ENV=test

# ============ Uploads / Upload Studio ============
UPLOAD_DIR=./var/uploads
MAX_UPLOAD_MB=25
MAX_LESSON_INPUT_CHARS=12000

# ============ Telegram bot / Mini App ============
TELEGRAM_BOT_TOKEN=
TELEGRAM_WEBAPP_URL=https://your-domain.com

# ============ Admin bootstrap (dev only) ============
ADMIN_BOOTSTRAP_EMAIL=admin@example.com
ADMIN_BOOTSTRAP_PASSWORD=change_me_admin_password

# ============ Self-hosted / licensing ============
LICENSE_SERVER_URL=https://license.your-domain.com
LICENSE_PUBLIC_KEY=change_me
SELF_HOSTED_MODE=true

# ============ CORS (dev; not needed when served same-origin behind nginx) ============
CORS_ORIGINS=http://localhost:3000,http://localhost:8080

# --- Security: upload malware scanning (ClamAV) ---
# The self-hosted compose ships a clamav service; leave enabled to scan every upload.
MALWARE_SCAN_ENABLED=true
CLAMAV_HOST=clamav
CLAMAV_PORT=3310
# If the scanner is down: false = allow uploads with a warning; true = reject (fail closed).
MALWARE_SCAN_FAIL_CLOSED=false
